{
  "name": "second-brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "dev:api": "node server/dev-api.mjs",
    "dev:full": "sh -c 'node server/dev-api.mjs & vite --host 0.0.0.0'",
    "smoke": "node scripts/smoke-app.mjs",
    "dev:fastapi": "PYTHONPATH=. python3 -m uvicorn fastapi_service.main:app --host 0.0.0.0 --port 8787",
    "dev:full:fastapi": "sh -c 'PYTHONPATH=. python3 -m uvicorn fastapi_service.main:app --host 0.0.0.0 --port 8787 & vite --host 0.0.0.0'",
    "test:fastapi": "PYTHONPATH=. python3 -m unittest fastapi_service.test_contract"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "puppeteer-core": "^24.43.0",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
