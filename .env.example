# Optional local provider. Server-side only; never expose this value in browser code.
OPENAI_API_KEY=

# Preferred companion model for server-side insight generation.
SECOND_BRAIN_MODEL=gpt-5.5-pro
OPENAI_MODEL=gpt-5.5-pro

# Remote Second Brain Express service from the product API docs.
SECOND_BRAIN_API_BASE_URL=http://206.189.235.67:8787
SECOND_BRAIN_API_TOKEN=

# Optional local session gate for direct OpenAI mode.
COMPANION_API_TOKEN=

# Local API helper port used by npm run dev:api and Vite proxy.
API_PORT=8787

# Optional CORS origin for the local/serverless API.
CORS_ALLOW_ORIGIN=http://localhost:5173
